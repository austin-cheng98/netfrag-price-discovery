# Copy to .env and fill what you have. Every key is OPTIONAL — the pipeline
# degrades to keyless sources (Arctic Shift, Nasdaq, Ollama) if a key is absent.
FINNHUB_API_KEY=
TIINGO_API_KEY=
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
FMP_API_KEY=
# Reddit app creds are only needed for LIVE going-forward collection (PRAW);
# historical event windows use Arctic Shift and need no key.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=netfrag-research/0.1 by u/yourname
